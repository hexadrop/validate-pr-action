{
  "name": "@hexadrop/validate-pr-action",
  "version": "1.0.1",
  "private": true,
  "description": "GitHub Action to validate pull requests against issue linkage, approval labels, type labels and changesets.",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}
